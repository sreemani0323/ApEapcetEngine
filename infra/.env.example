# ============================================================
# EAPCET Intelligence Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── PostgreSQL (Supabase) ───
DB_URL=jdbc:postgresql://localhost:5432/eapcet_db
DB_USERNAME=postgres
DB_PASSWORD=

# ─── ML Service ───
ML_SERVICE_URL=http://localhost:8000

# ─── Data Pipeline (Python scripts) ───
# These are used by data-pipeline/shared/db_config.py
DB_USER=postgres
DB_PASS=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eapcet_db
