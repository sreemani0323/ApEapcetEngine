{
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "apps/frontend/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://eapcet-backend.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
